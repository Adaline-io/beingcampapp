{
  "name": "beingcamp-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "BeingCamp — creative-community ecosystem app (React + Vite + Supabase).",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css}\"",
    "test:e2e": "playwright test",
    "cap:sync": "npm run build && cap sync",
    "cap:android": "npm run cap:sync && cap open android",
    "cap:ios": "npm run cap:sync && cap open ios",
    "db:start": "supabase start",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:seed": "supabase db reset"
  },
  "dependencies": {
    "@capacitor/core": "^6.2.1",
    "@supabase/supabase-js": "^2.45.4",
    "gsap": "^3.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "@eslint/js": "^9.11.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.185.1",
    "eslint": "^9.11.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^15.9.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.4.8",
    "vite-plugin-pwa": "^0.20.5"
  }
}
