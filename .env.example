# BeingCamp environment
#
# Copy this file to `.env` and fill in your Supabase project values.
# Without these, the app runs in local/demo mode (localStorage) — it still works,
# it just isn't backed by the database yet.
#
# Find these in your Supabase project: Settings → API.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
